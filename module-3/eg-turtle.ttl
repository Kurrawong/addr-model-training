PREFIX addr: <https://linked.data.gov.au/def/addr/>
PREFIX apt: <http://linked.data.gov.au/def/address-part-types/>
PREFIX ex: <http://example.com/>
PREFIX schema: <https://schema.org/>
PREFIX xsd: <http://www.w3.org/2001/XMLSchema#>

ex:oxford
    a addr:Address ;
    schema:hasPart 
        [
            schema:additionalType apt:road ;
            schema:value <https://linked.data.gov.au/dataset/qldaddr/streetLocality/QLD140492> ;
        ] ,
        [
            schema:additionalType apt:numberFirst ;
            schema:value 20 ;
        ] ;
.
